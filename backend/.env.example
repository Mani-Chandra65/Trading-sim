# Copy this file to .env and replace with your values
# cp .env.example .env

MYSQL_URL=jdbc:mysql://localhost:3306/binance?sslMode=REQUIRED&serverTimezone=UTC
MYSQL_USERNAME=your_mysql_username
MYSQL_PASSWORD=your_mysql_password

AUTH_TOKEN_TTL_HOURS=12
AUTH_ROLLING_REFRESH_MINUTES=30

# MARKET_PROVIDER: binance (real public data) or simulated
MARKET_PROVIDER=binance
BINANCE_BASE_URL=https://api.binance.com
MARKET_REQUEST_TIMEOUT_MS=5000
